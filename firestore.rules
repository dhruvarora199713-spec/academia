rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // Sub-collection: meta (seed marker)
      match /meta/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Students ─────────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isOwner(studentId);
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId);
    }

    // ─── Academic Collections (seeded by authenticated users, read by anyone authenticated) ─
    match /subjects/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /assignments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /exams/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /results/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /notifications/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Default: Deny ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
